<div class="govuk-width-container">
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">Development access</h1>

      <%= form_with url: development_access_path, scope: :development_access do |f| %>
        <%= f.govuk_text_field :password, type: "password", label: { text: "Password" } %>
        <%= f.govuk_submit "Continue" %>
      <% end %>
    </div>
  </div>
</div>
